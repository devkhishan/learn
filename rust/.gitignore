# Compiled Rust output and build artifacts for all nested Cargo projects
**/target/

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which will thus
# fall under the Cargo target directory, but we include them here
# in case they're generated outside it
*.pdb

# IDEs and editors (optional but recommended)
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db
